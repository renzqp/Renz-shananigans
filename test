-- REJOIN AFTER 45 MINUTES (AUTO ENABLED)
-- ==============================

local rejoinEnabled = true -- AUTO ENABLED
local timerRunning = false
local timeLeft = 2700

local TimerLabel = AfkTab:Paragraph({
    Title = "Rejoin Timer",
    Desc = "Starting..."
})

local function startTimer()

    if timerRunning then return end
    timerRunning = true
    timeLeft = 2700

    task.spawn(function()

        while rejoinEnabled and timeLeft > 0 do

            local minutes = math.floor(timeLeft / 60)
            local seconds = timeLeft % 60

            TimerLabel:SetDesc(string.format("%02d:%02d", minutes, seconds))

            task.wait(1)
            timeLeft -= 1

        end

        if rejoinEnabled then
            pcall(function()
                rejoinSameServer()
            end)
        end

        timerRunning = false

    end)

end

