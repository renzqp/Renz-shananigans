-- ==============================
-- ESP SYSTEM (FIXED)
-- ==============================
local ESPHighlights = {}
local espConnection

local function getRoleColor(plr)

    local color = Color3.fromRGB(0,255,0)

    local function hasTool(tool)
        if plr.Backpack:FindFirstChild(tool) then return true end
        if plr.Character and plr.Character:FindFirstChild(tool) then return true end
        return false
    end

    if hasTool("Knife") then
        color = Color3.fromRGB(255,0,0)
    elseif hasTool("Gun") then
        color = Color3.fromRGB(0,0,255)
    end

    return color
end

local function removeHighlight(plr)
    if ESPHighlights[plr] then
        ESPHighlights[plr]:Destroy()
        ESPHighlights[plr] = nil
    end
end

local function applyESP(plr)

    if plr == player then return end
    if not plr.Character then
        removeHighlight(plr)
        return
    end

    if not ESPHighlights[plr] then
        local highlight = Instance.new("Highlight")
        highlight.Adornee = plr.Character
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.FillTransparency = 0.35
        highlight.Parent = workspace
        ESPHighlights[plr] = highlight
    end

    local color = getRoleColor(plr)
    ESPHighlights[plr].FillColor = color
    ESPHighlights[plr].OutlineColor = color

end

local function clearAllESP()
    for _,highlight in pairs(ESPHighlights) do
        if highlight then
            highlight:Destroy()
        end
    end
    ESPHighlights = {}
end

ESPSection:Toggle({
    Title = "Role ESP",
    Default = Config.ESPEnabled,
    Callback = function(state)

        Config.ESPEnabled = state
        SaveConfig()

        if state then

            espConnection = RunService.RenderStepped:Connect(function()
                for _,plr in pairs(Players:GetPlayers()) do
                    applyESP(plr)
                end
            end)

            for _,plr in pairs(Players:GetPlayers()) do

                plr.CharacterRemoving:Connect(function()
                    removeHighlight(plr)
                end)

                plr.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    applyESP(plr)
                end)

            end

        else

            if espConnection then
                espConnection:Disconnect()
                espConnection = nil
            end

            clearAllESP()

        end

    end
})

