-- ==============================
-- BOX TAB
-- ==============================
local BoxesTab = Window:Tab({ Title = "Boxes", Icon = "box" })
local BoxSection = BoxesTab:Section({ Title = "Box Settings", Open = true })

local crates = {
    "KnifeBox1","KnifeBox2","KnifeBox3","KnifeBox4","KnifeBox5",
    "GunBox1","GunBox2","GunBox3","GunBox4","GunBox5",
    "MysteryBox1","MysteryBox2"
}

local selectedCrate = Config.SelectedCrate
local autoOpen = Config.AutoOpen

BoxSection:Dropdown({
    Title = "Select Box",
    Values = crates,
    Callback = function(value)
        selectedCrate = value
        Config.SelectedCrate = value
        SaveConfig()
    end
})

local function getShop()
    local gui = player:WaitForChild("PlayerGui"):WaitForChild("MainGUI")
    local gameFrame = gui:FindFirstChild("Game")
    return gameFrame and gameFrame:FindFirstChild("Shop")
end

local function findCrateButton(crateName)
    local shop = getShop()
    if not shop then return nil end
    for _,v in pairs(shop:GetDescendants()) do
        if v:IsA("TextButton") or v:IsA("ImageButton") then
            if string.lower(v.Name):find(string.lower(crateName))
            or (v.Parent and string.lower(v.Parent.Name):find(string.lower(crateName))) then
                return v
            end
        end
    end
end

BoxSection:Toggle({
    Title = "Auto open boxes",
    Default = Config.AutoOpen,
    Callback = function(state)
        autoOpen = state
        Config.AutoOpen = state
        SaveConfig()
        if autoOpen then
            task.spawn(function()
                while autoOpen do
                    if selectedCrate then
                        local crateButton = findCrateButton(selectedCrate)
                        if crateButton then
                            pcall(function()
                                if crateButton.MouseButton1Click then
                                    firesignal(crateButton.MouseButton1Click)
                                else
                                    crateButton:Activate()
                                end
                            end)
                        end
                    end
                    task.wait(1)
                end
            end)
        end
    end
})

-- ==============================
-- PERFORMANCE TAB
-- ==============================
local PerfTab = Window:Tab({ Title = "Performance", Icon = "zap" })
local PerfSection = PerfTab:Section({ Title = "Performance Settings", Open = true })

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local potatoEnabled = Config.PotatoMode
local saved = {}

local function save(obj,prop)
    saved[obj] = saved[obj] or {}
    if saved[obj][prop] == nil then
        saved[obj][prop] = obj[prop]
    end
end

local function optimize(obj)
    if obj:IsA("Decal") or obj:IsA("Texture") then
        save(obj,"Transparency")
        obj.Transparency = 1
    end
    if obj:IsA("BasePart") then
        save(obj,"Transparency")
        save(obj,"Material")
        save(obj,"Reflectance")
        obj.Transparency = 1
        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0
        obj.CastShadow = false
    end
    if obj:IsA("ParticleEmitter")
    or obj:IsA("Trail")
    or obj:IsA("Beam")
    or obj:IsA("Smoke")
    or obj:IsA("Fire")
    or obj:IsA("Sparkles") then
        save(obj,"Enabled")
        obj.Enabled = false
    end
end

local function enablePotato()
    save(Lighting,"GlobalShadows")
    Lighting.GlobalShadows = false
    for _,v in ipairs(Workspace:GetDescendants()) do
        optimize(v)
    end
    for _,effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            save(effect,"Enabled")
            effect.Enabled = false
        end
    end
end

local function disablePotato()
    for obj,props in pairs(saved) do
        if obj and obj.Parent then
            for prop,val in pairs(props) do
                obj[prop] = val
            end
        end
    end
    saved = {}
end

Workspace.DescendantAdded:Connect(function(obj)
    if potatoEnabled then
        task.defer(function()
            if obj and obj.Parent then
                optimize(obj)
            end
        end)
    end
end)

local function monitorPlayer(plr)
    plr.CharacterAdded:Connect(function(char)
        if not potatoEnabled then return end
        task.wait(0.5)
        for _,v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                save(v,"Transparency")
                v.Transparency = 1
            elseif v:IsA("Decal") then
                save(v,"Transparency")
                v.Transparency = 1
            elseif v:IsA("ParticleEmitter")
            or v:IsA("Trail")
            or v:IsA("Fire")
            or v:IsA("Smoke") then
                save(v,"Enabled")
                v.Enabled = false
            end
        end
    end)
end

for _,plr in pairs(Players:GetPlayers()) do
    if plr ~= player then
        monitorPlayer(plr)
    end
end

Players.PlayerAdded:Connect(function(plr)
    if plr ~= player then
        monitorPlayer(plr)
    end
end)

