-- ==============================
-- Potato Mode Toggle
-- ==============================
PerfSection:Toggle({
    Title = "Potato Mode",
    Default = false,
    Callback = function(state)
        potatoEnabled = state
        if potatoEnabled then
            enablePotato()
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= player and plr.Character then
                    hideOtherPlayers(plr.Character)
                end
            end
        else
            disablePotato()
        end
    end
})

-- Potato Mode Keybind
PerfSection:Keybind({
    Title = "Potato Mode Keybind",
    Key = Enum.KeyCode.P,
    Callback = function()
        potatoEnabled = not potatoEnabled
        if potatoEnabled then
            enablePotato()
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= player and plr.Character then
                    hideOtherPlayers(plr.Character)
                end
            end
        else
            disablePotato()
        end
    end
})
