-- ==============================
-- BOX TAB
-- ==============================
local BoxesTab = Window:Tab({ Title = "Boxes", Icon = "box" })
local BoxSection = BoxesTab:Section({ Title = "Box Settings", Open = true })

local crates = {
    "KnifeBox1","KnifeBox2","KnifeBox3","KnifeBox4","KnifeBox5",
    "GunBox1","GunBox2","GunBox3","GunBox4","GunBox5",
    "MysteryBox1","MysteryBox2"
}

local selectedCrate = Config.SelectedCrate
local autoOpen = Config.AutoOpen

BoxSection:Dropdown({
    Title = "Select Box",
    Values = crates,
    Callback = function(value)
        selectedCrate = value
        Config.SelectedCrate = value
        SaveConfig()
    end
})

local function getShop()
    local gui = player:WaitForChild("PlayerGui"):WaitForChild("MainGUI")
    local gameFrame = gui:FindFirstChild("Game")
    return gameFrame and gameFrame:FindFirstChild("Shop")
end

local function findCrateButton(crateName)
    local shop = getShop()
    if not shop then return nil end

    for _,v in pairs(shop:GetDescendants()) do
        if v:IsA("TextButton") or v:IsA("ImageButton") then
            if string.lower(v.Name):find(string.lower(crateName))
            or (v.Parent and string.lower(v.Parent.Name):find(string.lower(crateName))) then
                return v
            end
        end
    end
end

BoxSection:Toggle({
    Title = "Auto open boxes",
    Default = Config.AutoOpen,
    Callback = function(state)

        autoOpen = state
        Config.AutoOpen = state
        SaveConfig()

        if autoOpen then
            task.spawn(function()

                while autoOpen do

                    if selectedCrate then

                        local crateButton = findCrateButton(selectedCrate)

                        if crateButton then

                            pcall(function()

                                -- click crate
                                if crateButton.MouseButton1Click then
                                    firesignal(crateButton.MouseButton1Click)
                                else
                                    crateButton:Activate()
                                end

                            end)

                            task.wait(1)

                            -- press open button
                            local gui = player.PlayerGui:FindFirstChild("CrateOpening", true)

                            if gui then
                                local openButton = gui:FindFirstChildWhichIsA("TextButton", true)

                                if openButton then
                                    pcall(function()
                                        openButton:Activate()
                                    end)
                                end
                            end

                        end

                    end

                    task.wait(6)

                end

            end)
        end
    end
})
