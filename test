-- Load WindUI
local WindUI = loadstring(game:HttpGet(
"https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"
))()

local Window = WindUI:CreateWindow({
    Title = "MM2 Utility",
    Size = UDim2.fromOffset(320,260)
})

-- Boxes Tab
local BoxesTab = Window:Tab({ Title = "Boxes", Icon = "box" })
local Section = BoxesTab:Section({ Title = "Box Settings", Open = true })

local crates = {
    "KnifeBox1","KnifeBox2","KnifeBox3","KnifeBox4","KnifeBox5",
    "GunBox1","GunBox2","GunBox3","GunBox4","GunBox5",
    "MysteryBox1","MysteryBox2"
}

local selectedCrate = nil
local autoOpen = false

Section:Dropdown({
    Title = "Select Box",
    Values = crates,
    Callback = function(value)
        selectedCrate = value
    end
})

local player = game.Players.LocalPlayer

local function getShop()
    local gui = player:WaitForChild("PlayerGui"):WaitForChild("MainGUI")
    local gameFrame = gui:FindFirstChild("Game")
    return gameFrame and gameFrame:FindFirstChild("Shop")
end

local function findCrateButton(crateName)
    local shop = getShop()
    if not shop then return nil end

    for _,v in ipairs(shop:GetDescendants()) do
        if v:IsA("TextButton") or v:IsA("ImageButton") then
            if string.find(string.lower(v.Name), string.lower(crateName)) then
                return v
            end
        end
    end

    return nil
end

Section:Toggle({
    Title = "Auto open boxes",
    Default = false,
    Callback = function(state)
        autoOpen = state

        if autoOpen then
            task.spawn(function()
                while autoOpen do
                    if selectedCrate then
                        local crateButton = findCrateButton(selectedCrate)

                        if crateButton then
                            crateButton:Activate()
                        end
                    end

                    task.wait(0.4)
                end
            end)
        end
    end
})

-- Performance Tab
local PerfTab = Window:Tab({ Title = "Performance", Icon = "zap" })
local PerfSection = PerfTab:Section({ Title = "Performance Settings", Open = true })

local lighting = game:GetService("Lighting")
local workspace = game:GetService("Workspace")

local potatoEnabled = false
local saved = {}

local function save(obj,prop)
	saved[obj] = saved[obj] or {}
	if saved[obj][prop] == nil then
		saved[obj][prop] = obj[prop]
	end
end

local function optimize(obj)

	if obj:IsA("Decal") or obj:IsA("Texture") then
		save(obj,"Transparency")
		obj.Transparency = 1
	end

	if obj:IsA("BasePart") then
		save(obj,"Transparency")
		save(obj,"Material")
		save(obj,"Reflectance")

		obj.Transparency = 1
		obj.Material = Enum.Material.SmoothPlastic
		obj.Reflectance = 0
	end

	if obj:IsA("ParticleEmitter")
	or obj:IsA("Trail")
	or obj:IsA("Beam")
	or obj:IsA("Smoke")
	or obj:IsA("Fire")
	or obj:IsA("Sparkles") then
		
		save(obj,"Enabled")
		obj.Enabled = false
	end

end

local function enablePotato()

	save(lighting,"GlobalShadows")
	lighting.GlobalShadows = false

	for _,v in ipairs(workspace:GetDescendants()) do
		optimize(v)
	end

	for _,effect in pairs(lighting:GetChildren()) do
		if effect:IsA("PostEffect") then
			save(effect,"Enabled")
			effect.Enabled = false
		end
	end

end

local function disablePotato()

	for obj,props in pairs(saved) do
		if obj and obj.Parent then
			for prop,val in pairs(props) do
				obj[prop] = val
			end
		end
	end

	saved = {}

end

PerfSection:Toggle({
    Title = "Potato Mode",
    Default = false,
    Callback = function(state)
        potatoEnabled = state

        if potatoEnabled then
            enablePotato()
        else
            disablePotato()
        end
    end
})

PerfSection:Keybind({
    Title = "Potato Mode Keybind",
    Key = Enum.KeyCode.P,
    Callback = function()
        potatoEnabled = not potatoEnabled

        if potatoEnabled then
            enablePotato()
        else
            disablePotato()
        end
    end
})
