-- ==============================
-- INFO TAB WITH MINI-WINDOWS
-- ==============================
local REJOIN_INTERVAL = 2700
local rejoinCountdown = REJOIN_INTERVAL
local frameCount = 0
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")

local InfoTab = Window:Tab({ Title = "Info", Icon = "info" })
local InfoSection = InfoTab:Section({ Title = "Client Info", Open = true })

local fpsWindow
local timerWindow

-- FPS counting continuously
RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
end)

-- 45-minute countdown continuously
task.spawn(function()
    while true do
        task.wait(1)
        rejoinCountdown = rejoinCountdown - 1
        if rejoinCountdown <= 0 then
            rejoinCountdown = REJOIN_INTERVAL
            TeleportService:Teleport(game.PlaceId, player)
        end
    end
end)

-- FPS Window Toggle
InfoSection:Toggle({
    Title = "Enable FPS Window",
    Default = false,
    Callback = function(state)
        if state then
            task.spawn(function()
                repeat task.wait() until Window.Frame and Window.Frame.Parent
                if fpsWindow then return end
                fpsWindow = WindUI:CreateWindow({Title="FPS", Size=UDim2.fromOffset(200,50)})
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1,0,1,0)
                label.TextColor3 = Color3.new(1,1,1)
                label.BackgroundTransparency = 1
                label.TextScaled = true
                label.Parent = fpsWindow.Frame

                task.spawn(function()
                    while fpsWindow and fpsWindow.Frame and fpsWindow.Frame.Parent do
                        label.Text = "FPS: "..frameCount
                        frameCount = 0
                        task.wait(1)
                    end
                end)
            end)
        else
            if fpsWindow and fpsWindow.Frame then
                fpsWindow.Frame:Destroy()
                fpsWindow = nil
            end
        end
    end
})

-- Timer Window Toggle
InfoSection:Toggle({
    Title = "Enable Timer Window",
    Default = false,
    Callback = function(state)
        if state then
            task.spawn(function()
                repeat task.wait() until Window.Frame and Window.Frame.Parent
                if timerWindow then return end
                timerWindow = WindUI:CreateWindow({Title="Auto-Rejoin Timer", Size=UDim2.fromOffset(200,50)})
                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1,0,1,0)
                label.TextColor3 = Color3.new(1,1,1)
                label.BackgroundTransparency = 1
                label.TextScaled = true
                label.Parent = timerWindow.Frame

                task.spawn(function()
                    while timerWindow and timerWindow.Frame and timerWindow.Frame.Parent do
                        local minutes = math.floor(rejoinCountdown/60)
                        local seconds = rejoinCountdown % 60
                        label.Text = string.format("%02d:%02d", minutes, seconds)
                        task.wait(1)
                    end
                end)
            end)
        else
            if timerWindow and timerWindow.Frame then
                timerWindow.Frame:Destroy()
                timerWindow = nil
            end
        end
    end
})
