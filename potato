-- ==============================
-- SAFE POTATO MODE (FOR EXISTING "Visuals" TAB)
-- ==============================

local potatoEnabled = Config.PotatoMode
local saved = {}
local potatoConnection

local function save(obj, prop)
    saved[obj] = saved[obj] or {}
    if saved[obj][prop] == nil then
        saved[obj][prop] = obj[prop]
    end
end

local function optimize(obj)
    -- Never touch the GUI
    if obj:IsDescendantOf(playerGui) then return end

    -- Decals / textures
    if obj:IsA("Decal") or obj:IsA("Texture") then
        save(obj, "Transparency")
        obj.Transparency = 1

    -- Particles / effects
    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
        save(obj, "Enabled")
        obj.Enabled = false

    elseif obj:IsA("Smoke") or obj:IsA("Fire") then
        save(obj, "Enabled")
        obj.Enabled = false

    elseif obj:IsA("Explosion") then
        obj:Destroy()
    end
end

local function enablePotato()
    potatoEnabled = true

    save(Lighting, "GlobalShadows")
    Lighting.GlobalShadows = false

    -- Clean everything once
    for _, v in ipairs(Workspace:GetDescendants()) do
        optimize(v)
    end

    -- Connect to new objects
    potatoConnection = Workspace.DescendantAdded:Connect(function(obj)
        if potatoEnabled then
            optimize(obj)
        end
    end)

    -- Constant loop
    task.spawn(function()
        while potatoEnabled do
            for _, v in ipairs(Workspace:GetDescendants()) do
                optimize(v)
            end
            task.wait(3)
        end
    end)
end

local function disablePotato()
    potatoEnabled = false

    if potatoConnection then
        potatoConnection:Disconnect()
        potatoConnection = nil
    end

    -- Restore saved properties
    for obj, props in pairs(saved) do
        if obj and obj.Parent then
            for prop, val in pairs(props) do
                obj[prop] = val
            end
        end
    end

    saved = {}
end

-- Add the toggle into your existing "Visuals" section
PerfSection:Toggle({
    Title = "Potato Mode",
    Default = Config.PotatoMode,
    Callback = function(state)
        Config.PotatoMode = state
        SaveConfig()

        if state then
            enablePotato()
        else
            disablePotato()
        end
    end
})
